{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$(git rev-parse --show-toplevel)\\.codex\\hooks\\stop-test-and-commit.ps1\"",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$(git rev-parse --show-toplevel)/.codex/hooks/stop-test-and-commit.ps1\"",
            "timeout": 60,
            "statusMessage": "Testing and committing index.html"
          }
        ]
      }
    ]
  }
}
